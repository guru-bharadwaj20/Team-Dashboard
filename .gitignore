```gitignore
# ==========================================================
# Dependencies
# ==========================================================
node_modules/
**/node_modules/

# ==========================================================
# Environment Variables (NEVER COMMIT)
# ==========================================================
.env
.env.*
.env.local
.env.*.local

backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

# ==========================================================
# Logs
# ==========================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================================
# Build Outputs
# ==========================================================
dist/
dist-ssr/
build/
out/

frontend/dist/
backend/dist/

# ==========================================================
# Coverage & Testing
# ==========================================================
coverage/
.nyc_output/

# ==========================================================
# Cache Files
# ==========================================================
.npm/
.eslintcache
.cache/
.parcel-cache/
.vite/

# ==========================================================
# Operating System Files
# ==========================================================
.DS_Store
Thumbs.db
Desktop.ini

# ==========================================================
# IDE / Editor
# ==========================================================
.vscode/
.idea/

*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# ==========================================================
# Database Files
# ==========================================================
*.db
*.sqlite
*.sqlite3

# ==========================================================
# Temporary Files
# ==========================================================
tmp/
temp/
*.tmp

# ==========================================================
# Local Configuration
# ==========================================================
*.local

# ==========================================================
# Runtime Files
# ==========================================================
pids/
*.pid
*.seed
*.pid.lock

# ==========================================================
# Optional Debug Files
# ==========================================================
*.tgz
*.bak
*.orig

# ==========================================================
# macOS Metadata
# ==========================================================
.AppleDouble
.LSOverride

# ==========================================================
# Linux Metadata
# ==========================================================
*~

# ==========================================================
# Windows Metadata
# ==========================================================
ehthumbs.db
Icon?

# ==========================================================
# Ignore generated PDFs or exports (optional)
# Uncomment if export folder exists
# ==========================================================
# exports/
# generated/
```
